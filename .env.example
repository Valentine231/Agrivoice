# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — database + auth. Find these in your Supabase project under
# Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER-ONLY, never exposed to the browser. Used to
# release escrow payments and mark orders in_escrow/completed. Settings → API
# → "service_role" (click reveal).
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary — used to store farmer harvest photos (not in the database)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# Find it in your Cloudinary dashboard under Settings → API Keys → "API Environment variable"
CLOUDINARY_URL=

# Paystack — used for escrow-style payments
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

